DASHSCOPE_API_KEY=your_dashscope_key_here
QWEN_MODEL=qwen3.6-flash

# Open-source model (for local activation extraction)
# TransformerLens supports: gpt2, gpt-neo, llama, mistral, gemma, etc.
MODEL_NAME=google/gemma-2-2b
# Optional: set this on Mac mini if the model is already downloaded locally.
# Leave unset on MacBook Air unless it has the same local model path.
# LOCAL_GEMMA_MODEL=/Users/her/Project/ai-models/gemma-2-2b
HF_TOKEN=your_hf_token_here

# Experiment config
DEVICE=cuda   # or cpu / mps
BATCH_SIZE=8
RANDOM_SEED=42
