      "pc3": 3.163435697555542
    },
    {
      "id": "S035",
      "text": "知人者智，自知者明。",
      "ref": "老子, 道德經",
      "cluster": 3,
      "cluster_name": "Chinese self-cultivation / transformation",
      "pc1": -13.344306945800781,
      "pc2": -17.495595932006836,
      "pc3": 5.190307140350342
    },
    {
      "id": "S036",
      "text": "勝人者有力，自勝者強。",
      "ref": "老子, 道德經",
      "cluster": 3,
      "cluster_name": "Chinese self-cultivation / transformation",
      "pc1": -11.76508903503418,
      "pc2": -10.736075401306152,
      "pc3": 3.9800710678100586
    },
    {
      "id": "S037",
      "text": "吾日三省吾身。",
      "ref": "論語, 學而",
      "cluster": 3,
      "cluster_name": "Chinese self-cultivation / transformation",
      "pc1": -11.810250282287598,
      "pc2": -22.157426834106445,
      "pc3": -2.643202781677246
    },
    {
      "id": "S038",
      "text": "盡其心者，知其性也。",
      "ref": "孟子, 盡心上",
      "cluster": 3,
      "cluster_name": "Chinese self-cultivation / transformation",
      "pc1": -12.952258110046387,
      "pc2": -19.832305908203125,
      "pc3": 7.7177863121032715
    },
    {
      "id": "S039",
      "text": "知其性，則知天矣。",
      "ref": "孟子, 盡心上",
      "cluster": 3,
      "cluster_name": "Chinese self-cultivation / transformation",
      "pc1": -14.091119766235352,
      "pc2": -20.315288543701172,
      "pc3": 6.222501754760742
    },
    {
      "id": "S040",
      "text": "Trust thyself: every heart vibrates to that iron string.",
      "ref": "Emerson, Self-Reliance",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 7.042458534240723,
      "pc2": 0.2822418212890625,
      "pc3": 4.578446388244629
    },
    {
      "id": "S041",
      "text": "Nothing is at last sacred but the integrity of your own mind.",
      "ref": "Emerson, Self-Reliance",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 5.768090724945068,
      "pc2": 1.7620562314987183,
      "pc3": 4.268618106842041
    },
    {
      "id": "S042",
      "text": "Que sais-je?",
      "ref": "Montaigne, Essays",
      "cluster": 0,
      "cluster_name": "Non-self, nothingness, negation",
      "pc1": -5.232353687286377,
      "pc2": -1.3535802364349365,
      "pc3": -6.2546491622924805
    },
    {
      "id": "S043",
      "text": "If the doors of perception were cleansed every thing would appear to man as it is, infinite.",
      "ref": "William Blake, The Marriage of Heaven and Hell",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 7.44628381729126,
      "pc2": 5.437344551086426,
      "pc3": 7.427824020385742
    },
    {
      "id": "S044",
      "text": "For man has closed himself up, till he sees all things thro' narrow chinks of his cavern.",
      "ref": "William Blake, The Marriage of Heaven and Hell",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 6.417574405670166,
      "pc2": 0.889007031917572,
      "pc3": 2.6970999240875244
    },
    {
      "id": "S045",
      "text": "I celebrate myself, and sing myself.",
      "ref": "Whitman, Song of Myself",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 12.981830596923828,
      "pc2": -7.489346504211426,
      "pc3": -21.51485824584961
    },
    {
      "id": "S046",
      "text": "For every atom belonging to me as good belongs to you.",
      "ref": "Whitman, Song of Myself",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 6.384889602661133,
      "pc2": 0.5558717846870422,
      "pc3": 4.119208812713623
    },
    {
      "id": "S047",
      "text": "I loafe and invite my soul.",
      "ref": "Whitman, Song of Myself",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 7.714678764343262,
      "pc2": -4.3305768966674805,
      "pc3": -11.649747848510742
    },
    {
      "id": "S048",
      "text": "Do I contradict myself? Very well then I contradict myself.",
      "ref": "Whitman, Song of Myself",
      "cluster": 7,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 7.892168998718262,
      "pc2": -1.211856722831726,
      "pc3": -5.696287155151367
    },
    {
      "id": "S049",
      "text": "I am large, I contain multitudes.",
      "ref": "Whitman, Song of Myself",
      "cluster": 7,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 8.611885070800781,
      "pc2": -0.0015672622248530388,
      "pc3": -7.445598602294922
    },
    {
      "id": "S050",
      "text": "I'm Nobody! Who are you?",
      "ref": "Emily Dickinson, I'm Nobody! Who are you?",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 12.001883506774902,
      "pc2": -8.184487342834473,
      "pc3": -21.394514083862305
    },
    {
      "id": "S051",
      "text": "Are you — Nobody — too?",
      "ref": "Emily Dickinson, I'm Nobody! Who are you?",
      "cluster": 7,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 7.371011257171631,
      "pc2": -0.8174993991851807,
      "pc3": -6.265408992767334
    },
    {
      "id": "S052",
      "text": "How dreary — to be — Somebody!",
      "ref": "Emily Dickinson, I'm Nobody! Who are you?",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 7.149356842041016,
      "pc2": -0.4502429962158203,
      "pc3": -7.306005477905273
    },
    {
      "id": "S053",
      "text": "How public — like a Frog —",
      "ref": "Emily Dickinson, I'm Nobody! Who are you?",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 4.125297546386719,
      "pc2": 0.845556378364563,
      "pc3": -2.327718734741211
    },
    {
      "id": "S054",
      "text": "The Brain—is wider than the Sky—",
      "ref": "Emily Dickinson, The Brain—is wider than the Sky",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 4.274331092834473,
      "pc2": 3.645571231842041,
      "pc3": 6.355719089508057
    },
    {
      "id": "S055",
      "text": "The one the other will contain.",
      "ref": "Emily Dickinson, The Brain—is wider than the Sky",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 4.031908988952637,
      "pc2": 1.6479648351669312,
      "pc3": 1.4591904878616333
    },
    {
      "id": "S056",
      "text": "The Brain is deeper than the sea—",
      "ref": "Emily Dickinson, The Brain—is wider than the Sky",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 4.96173620223999,
      "pc2": 3.9329326152801514,
      "pc3": 5.24728536605835
    },
    {
      "id": "S057",
      "text": "Car Je est un autre.",
      "ref": "Rimbaud, Lettre à Paul Demeny",
      "cluster": 0,
      "cluster_name": "Non-self, nothingness, negation",
      "pc1": -6.2432451248168945,
      "pc2": 4.570969104766846,
      "pc3": -3.4428868293762207
    },
    {
      "id": "S058",
      "text": "J’assiste à l’éclosion de ma pensée.",
      "ref": "Rimbaud, Lettre à Paul Demeny",
      "cluster": 0,
      "cluster_name": "Non-self, nothingness, negation",
      "pc1": -6.441320419311523,
      "pc2": 3.547396421432495,
      "pc3": -0.1999935358762741
    },
    {
      "id": "S059",
      "text": "Zwei Seelen wohnen, ach! in meiner Brust.",
      "ref": "Goethe, Faust I",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -20.585403442382812,
      "pc2": 16.4218692779541,
      "pc3": -5.614938735961914
    },
    {
      "id": "S060",
      "text": "Die eine will sich von der andern trennen.",
      "ref": "Goethe, Faust I",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -15.810494422912598,
      "pc2": 14.039973258972168,
      "pc3": -4.580427646636963
    },
    {
      "id": "S061",
      "text": "Denn da ist keine Stelle, die dich nicht sieht.",
      "ref": "Rilke, Archaischer Torso Apollos",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -17.784770965576172,
      "pc2": 15.989931106567383,
      "pc3": -6.037851333618164
    },
    {
      "id": "S062",
      "text": "Du mußt dein Leben ändern.",
      "ref": "Rilke, Archaischer Torso Apollos",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -13.100542068481445,
      "pc2": 12.858575820922852,
      "pc3": -3.6960322856903076
    },
    {
      "id": "S063",
      "text": "Who is it that can tell me who I am?",
      "ref": "Shakespeare, King Lear",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 5.932368278503418,
      "pc2": 0.5553545951843262,
      "pc3": -1.8236498832702637
    },
    {
      "id": "S064",
      "text": "Lear's shadow.",
      "ref": "Shakespeare, King Lear",
      "cluster": 6,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": -0.23204751312732697,
      "pc2": -1.7083913087844849,
      "pc3": -1.8960785865783691
    },
    {
      "id": "S065",
      "text": "What a piece of work is a man!",
      "ref": "Shakespeare, Hamlet",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 9.680137634277344,
      "pc2": -5.694432735443115,
      "pc3": -12.654244422912598
    },
    {
      "id": "S066",
      "text": "How noble in reason! how infinite in faculty!",
      "ref": "Shakespeare, Hamlet",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 6.128511428833008,
      "pc2": -5.576662063598633,
      "pc3": -6.104700565338135
    },
    {
      "id": "S067",
      "text": "And yet, to me, what is this quintessence of dust?",
      "ref": "Shakespeare, Hamlet",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 7.751717567443848,
      "pc2": 1.4512447118759155,
      "pc3": 1.913192629814148
    },
    {
      "id": "S068",
      "text": "Life's but a walking shadow.",
      "ref": "Shakespeare, Macbeth",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 9.52340030670166,
      "pc2": -3.36833119392395,
      "pc3": -13.14080810546875
    },
    {
      "id": "S069",
      "text": "It is a tale told by an idiot, full of sound and fury, signifying nothing.",
      "ref": "Shakespeare, Macbeth",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 9.03052043914795,
      "pc2": -4.561883926391602,
      "pc3": -8.316085815429688
    },
    {
      "id": "S070",
      "text": "We are such stuff as dreams are made on.",
      "ref": "Shakespeare, The Tempest",
      "cluster": 1,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 10.347597122192383,
      "pc2": -6.440216064453125,
      "pc3": -16.577634811401367
    },
    {
      "id": "S071",
      "text": "Our little life is rounded with a sleep.",
      "ref": "Shakespeare, The Tempest",
      "cluster": 5,
      "cluster_name": "First-person certainty and self-reference",
      "pc1": 6.489381790161133,
      "pc2": 4.181601047515869,
      "pc3": -0.011500704102218151
    },
    {
      "id": "S072",
      "text": "Nach Innen geht der geheimnisvolle Weg.",
      "ref": "Novalis, Blüthenstaub",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -13.708955764770508,
      "pc2": 12.155052185058594,
      "pc3": -3.093228340148926
    },
    {
      "id": "S073",
      "text": "In uns, oder nirgends ist die Ewigkeit mit ihren Welten.",
      "ref": "Novalis, Blüthenstaub",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -16.224071502685547,
      "pc2": 15.53811264038086,
      "pc3": -3.6608893871307373
    },
    {
      "id": "S074",
      "text": "Die Tiefen unseres Geistes kennen wir nicht.",
      "ref": "Novalis, Blüthenstaub",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -16.509767532348633,
      "pc2": 13.39422607421875,
      "pc3": -1.732967495918274
    },
    {
      "id": "S075",
      "text": "Ein Zeichen sind wir, deutungslos.",
      "ref": "Hölderlin, Mnemosyne",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -15.807228088378906,
      "pc2": 16.480981826782227,
      "pc3": -2.8081438541412354
    },
    {
      "id": "S076",
      "text": "Schmerzlos sind wir und haben fast die Sprache in der Fremde verloren.",
      "ref": "Hölderlin, Mnemosyne",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -19.427623748779297,
      "pc2": 17.955429077148438,
      "pc3": -1.5230053663253784
    },
    {
      "id": "S077",
      "text": "Não sou nada.",
      "ref": "Fernando Pessoa / Álvaro de Campos, Tabacaria",
      "cluster": 0,
      "cluster_name": "Non-self, nothingness, negation",
      "pc1": -4.542113304138184,
      "pc2": -0.505458652973175,
      "pc3": -3.656911611557007
    },
    {
      "id": "S078",
      "text": "Nunca serei nada.",
      "ref": "Fernando Pessoa / Álvaro de Campos, Tabacaria",
      "cluster": 0,
      "cluster_name": "Non-self, nothingness, negation",
      "pc1": -5.855384349822998,
      "pc2": 0.11477874964475632,
      "pc3": -3.616318941116333
    },
    {
      "id": "S079",
      "text": "À parte isso, tenho em mim todos os sonhos do mundo.",
      "ref": "Fernando Pessoa / Álvaro de Campos, Tabacaria",
      "cluster": 0,
      "cluster_name": "Non-self, nothingness, negation",
      "pc1": -5.296792030334473,
      "pc2": 1.5192636251449585,
      "pc3": 2.3229453563690186
    },
    {
      "id": "S080",
      "text": "Wo Es war, soll Ich werden.",
      "ref": "Freud, Neue Folge der Vorlesungen",
      "cluster": 2,
      "cluster_name": "German/French inwardness and alterity",
      "pc1": -17.033451080322266,
      "pc2": 11.863367080688477,
      "pc3": -10.088078498840332
    }
  ]
}